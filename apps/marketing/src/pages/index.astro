---
const nextAppUrl = (import.meta.env.PUBLIC_NEXT_APP_URL || "http://localhost:3002").replace(
  /\/$/,
  ""
);
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>showreels.id | Marketing on Astro</title>
    <meta
      name="description"
      content="Halaman marketing showreels.id berjalan di Astro, dashboard creator tetap di Next.js."
    />
    <style>
      :root {
        --blue: #2f73ff;
        --blue-dark: #174bb4;
        --text: #162440;
        --muted: #5a6f98;
        --line: #d5e1f7;
        --bg: #f2f6ff;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Plus Jakarta Sans", "Segoe UI", sans-serif;
        background: radial-gradient(circle at top left, #ebf2ff 0%, #f8fbff 45%, #f4f7ff 100%);
        color: var(--text);
      }

      .container {
        width: min(1080px, calc(100% - 2rem));
        margin: 0 auto;
      }

      .surface {
        border: 1px solid var(--line);
        background: #fff;
        border-radius: 28px;
        box-shadow: 0 18px 54px rgba(25, 56, 120, 0.08);
      }

      header {
        padding: 1rem 0;
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.9rem 1rem;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        font-weight: 700;
        font-size: 1.2rem;
      }

      .brand-dot {
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #eff4ff;
        color: var(--blue);
        border: 1px solid #d7e4ff;
      }

      .actions {
        display: flex;
        gap: 0.6rem;
      }

      .btn {
        text-decoration: none;
        border-radius: 999px;
        border: 1px solid #cbdcf9;
        color: var(--text);
        background: #fff;
        font-size: 0.9rem;
        font-weight: 600;
        padding: 0.62rem 1rem;
        line-height: 1;
      }

      .btn.primary {
        background: linear-gradient(160deg, var(--blue), #3d84ff);
        border-color: transparent;
        color: #fff;
      }

      main {
        padding: 0.8rem 0 2rem;
      }

      .hero {
        padding: clamp(1.2rem, 3vw, 2.4rem);
      }

      .label {
        display: inline-flex;
        align-items: center;
        border: 1px solid #d6e3fa;
        color: #3563bf;
        border-radius: 999px;
        padding: 0.35rem 0.65rem;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 700;
      }

      h1 {
        margin: 0.85rem 0 0;
        font-size: clamp(2rem, 4.5vw, 3.35rem);
        line-height: 1.07;
        max-width: 13ch;
      }

      .lead {
        margin: 1rem 0 0;
        color: var(--muted);
        font-size: clamp(0.98rem, 1.8vw, 1.12rem);
        max-width: 56ch;
        line-height: 1.6;
      }

      .grid {
        margin-top: 1.3rem;
        display: grid;
        gap: 0.8rem;
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .card {
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 1rem;
        background: #fbfdff;
      }

      .card h2 {
        margin: 0;
        font-size: 1rem;
      }

      .card p {
        margin: 0.55rem 0 0;
        color: var(--muted);
        font-size: 0.9rem;
      }

      .footer-note {
        margin-top: 1.2rem;
        font-size: 0.85rem;
        color: #5f6f90;
      }

      @media (max-width: 900px) {
        .grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 640px) {
        .actions {
          width: 100%;
        }

        .actions .btn {
          flex: 1;
          text-align: center;
        }

        .grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <header class="container">
      <div class="surface nav">
        <div class="brand">
          <span class="brand-dot">⛓</span>
          showreels.id
        </div>
        <div class="actions">
          <a class="btn" href={`${nextAppUrl}/auth/login`}>Masuk</a>
          <a class="btn primary" href={`${nextAppUrl}/dashboard`}>Dashboard</a>
        </div>
      </div>
    </header>

    <main class="container">
      <section class="surface hero">
        <span class="label">Astro + Next Hybrid</span>
        <h1>Landing marketing di Astro, fitur aplikasi tetap di Next.</h1>
        <p class="lead">
          Integrasi hybrid aktif. Halaman promosi dan konten cepat di-render oleh Astro, sementara
          autentikasi, dashboard creator, billing, dan API tetap berjalan di aplikasi Next.js.
        </p>

        <div class="grid">
          <article class="card">
            <h2>Marketing (Astro)</h2>
            <p>Konten statis, SEO, dan performa landing page.</p>
          </article>
          <article class="card">
            <h2>App Core (Next)</h2>
            <p>Auth, dashboard, analytics, creator profile, dan billing.</p>
          </article>
          <article class="card">
            <h2>Checkout Flow</h2>
            <p>Flow subscription tetap mengarah ke endpoint billing yang sudah ada.</p>
          </article>
        </div>

        <p class="footer-note">
          Ubah base URL aplikasi Next lewat env <code>PUBLIC_NEXT_APP_URL</code>.
        </p>
      </section>
    </main>
  </body>
</html>
