# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/screenshots/

# next.js
/.next/
/out/

# production
/build
/apps/**/.astro/
/apps/**/dist/
/apps/**/node_modules/

