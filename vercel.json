{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm ci --legacy-peer-deps",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/trial-expiry",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/email-queue",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/audit-full",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/audit-api",
      "schedule": "*/30 * * * *"
    }
  ]
}
