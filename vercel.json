{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm ci --legacy-peer-deps",
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noai, noimageai" }
      ]
    }
  ],
  "functions": {
    "src/app/api/admin/audit/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/audit-full/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/audit-api/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/trial-expiry",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/email-queue",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/audit-full",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/audit-api",
      "schedule": "0 2 * * *"
    }
  ]
}
